{
  "version": 2,
  "builds": [
    { "src": "server.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/server.js" }
  ],
  "headers": [
    {
      "source": "/privacy-policy",
      "headers": [
        {
          "key": "Accept-Ranges",
          "value": "none"
        }
      ]
    }
  ]
}
